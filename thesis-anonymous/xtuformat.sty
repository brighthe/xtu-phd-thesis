% 1. 针对【章标题】的定制底层命令：黑体小四，段前6磅，行距20磅
\def\@bfdottedtocline#1#2#3#4#5{%
	\ifnum #1>\c@tocdepth \else
	\vskip 6pt \@plus.2\p@ % 【规范落实】段前空 6 磅 (替换了原有的 \z@)
	{\leftskip #2\relax \rightskip \@tocrmarg \parfillskip -\rightskip
		\parindent #2\relax\@afterindenttrue
		\interlinepenalty\@M
		% 【规范落实】黑体小四，并强制将该段落的基线距离(行距)锁定为 20pt
		\leavevmode \heiti\zihao{-4}\setlength{\baselineskip}{20pt}% 
		\@tempdima #3\relax
		\advance\leftskip \@tempdima \null\nobreak\hskip -\leftskip
		{#4}\normalfont\nobreak
		\leaders\hbox{$\m@th
			\mkern \@dotsep mu\hbox{.}\mkern \@dotsep
			mu$}\hfill
		\nobreak
		\hb@xt@\@pnumwidth{\hfil\normalfont \normalcolor #5}%
		\par}%
	\fi}

% 2. 针对【一级节、二级节标题】的定制底层命令：宋体小四，段前0磅，行距20磅
\def\@stdottedtocline#1#2#3#4#5{%
	\ifnum #1>\c@tocdepth \else
	\vskip \z@ \@plus.2\p@ % 【规范落实】段前空 0 磅
	{\leftskip #2\relax \rightskip \@tocrmarg \parfillskip -\rightskip
		\parindent #2\relax\@afterindenttrue
		\interlinepenalty\@M
		% 【规范落实】宋体小四，并强制行距锁定为 20pt
		\leavevmode \songti\zihao{-4}\setlength{\baselineskip}{20pt}% 
		\@tempdima #3\relax
		\advance\leftskip \@tempdima \null\nobreak\hskip -\leftskip
		{#4}\normalfont\nobreak
		\leaders\hbox{$\m@th
			\mkern \@dotsep mu\hbox{.}\mkern \@dotsep
			mu$}\hfill
		\nobreak
		\hb@xt@\@pnumwidth{\hfil\normalfont \normalcolor #5}%
		\par}%
	\fi}

% 3. 将格式绑定到具体的目录层级，并落实缩进要求
\renewcommand*\l@chapter{\@bfdottedtocline{0}{0em}{1.5em}} % 章标题：居左书写 (0em 缩进)
\renewcommand*\l@section{\@stdottedtocline{1}{1em}{2em}}   % 一级节标题：缩进1个汉字符 (1em)
\renewcommand*\l@subsection{\@stdottedtocline{2}{2em}{3em}}% 二级节标题：缩进2个汉字符 (2em)
\makeatother
