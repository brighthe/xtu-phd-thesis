%=========================================
% 中、英文摘要标题与正文格式
%
% 写作指南要求：
% 中文摘要标题为黑体三号、居中、单倍行距；
% 英文摘要标题为 Arial 三号加粗、居中、单倍行距；
% 标题段后为 18 磅；
% 中文摘要正文为小四号宋体，英文摘要正文为小四号 Times New Roman。
%
% 说明：
% 写作指南中摘要标题段前为 24 磅。
% 但本模板的页面版式已由 geometry 的上边距及页眉区域预留标题前空白，
% 若在摘要标题前继续叠加 24 磅，会导致摘要页顶部空白过大。
% 因此此处将标题前的附加垂直间距设为 0pt，
% 以保证最终输出效果与学位论文摘要页的视觉规范一致。
%=========================================

\newcommand{\xtucnabstracttitle}{%
	\vspace*{0pt}%
	{\centering\heiti\zihao{3}\linespread{1}\selectfont 摘~~~~要\par}%
	\vspace{18pt}%
}

\newcommand{\xtuenabstracttitle}{%
	\vspace*{0pt}%
	{\centering\fontspec{Arial}\bfseries\zihao{3}\linespread{1}\selectfont Abstract\par}%
	\vspace{18pt}%
}

\newcommand{\xtuabstractbodyformat}{%
	\zihao{-4}\selectfont
	\setlength{\baselineskip}{20pt}%
	\setlength{\parindent}{2em}%
	\setlength{\parskip}{0pt}%
}

%=========================================
% 中文摘要环境：标题“摘~~~~要”，正文小四号宋体、两端对齐；
% 目录从第1章开始，摘要不加入目录。
%=========================================

\newenvironment{cnabstract}{%
	\clearpage
	\thispagestyle{plain}
	\markboth{摘要}{摘要}
	\xtucnabstracttitle
	\begingroup
	\songti\xtuabstractbodyformat
	\ignorespaces
}{%
	\par
	\endgroup
	\ignorespacesafterend
}

%=========================================
% 中文关键词：小四号，关键词之间用分号间隔，数量不超过5个。
%=========================================

\newenvironment{cnkeywords}{%
	\par\vskip 0.6cm
	\noindent{\heiti\zihao{-4}\selectfont 关键词：}%
	\begingroup
	\songti\xtuabstractbodyformat
	\ignorespaces
}{%
	\par
	\endgroup
	\ignorespacesafterend
}

%=========================================
% 英文摘要环境：标题“Abstract”，正文小四号 Times New Roman、两端对齐；
% 目录从第1章开始，英文摘要不加入目录。
%=========================================

\newenvironment{enabstract}{%
	\clearpage
	\thispagestyle{plain}
	\markboth{Abstract}{Abstract}
	\xtuenabstracttitle
	\begingroup
	\fontspec{Times New Roman}\xtuabstractbodyformat
	\ignorespaces
}{%
	\par
	\endgroup
	\ignorespacesafterend
}

%=========================================
% 英文关键词：“Key Words”与中文关键词对应，关键词之间用分号间隔。
%=========================================

\newenvironment{enkeywords}{%
	\par\vskip 0.6cm
	\noindent{\fontspec{Times New Roman}\bfseries\zihao{-4}\selectfont Key Words: }%
	\begingroup
	\fontspec{Times New Roman}\xtuabstractbodyformat
	\ignorespaces
}{%
	\par
	\endgroup
	\ignorespacesafterend
}

%=========================================
% 全局标题编号深度设置
%=========================================
% 刚性设定标题编号深度为 4（章、一级节、二级节、三级节）
\setcounter{secnumdepth}{4}

%=========================================
% 正文各级标题格式全局配置 (基于现代 ctexset 键值对接口)
% 严格落实《写作指南》中关于标题字体、字号及段前段后间距的排版规范
%=========================================
\ctexset{
	chapter = {
		format={\centering\sffamily},          % 整体格式：居中排列，无衬线字体族
		nameformat={\heiti\zihao{3}},          % "第X章" 字样的格式：三号黑体
		titleformat={\heiti\zihao{3}},         % 标题具体内容的格式：三号黑体
		numberformat={\heiti\zihao{3}},        % 数字编号的格式：三号黑体
		beforeskip={0pt},afterskip={30pt},     % 间距：段前 0pt，段后 30pt (保证章标题下方有足够的呼吸感)
		name={第, 章},number={\arabic{chapter}}  % 样式：阿拉伯数字编号 (如 "第1章")
	},
	section = {
		format={\flushleft\sffamily\heiti\zihao{4}}, % 一级节标题：左对齐，四号黑体
		beforeskip={24pt},afterskip={6pt},           % 间距：段前 24pt，段后 6pt
	},
	subsection = {
		format={\flushleft\sffamily\heiti\zihao{-4}}, % 二级节标题：左对齐，小四号黑体
		beforeskip={12pt},afterskip={6pt},            % 间距：段前 12pt，段后 6pt
	},   
	subsubsection = {
		format={\flushleft\sffamily\heiti\zihao{-4}}, % 三级节标题：左对齐，小四号黑体
		beforeskip={12pt},afterskip={6pt},            % 间距：段前 12pt，段后 6pt
	}
}

%=========================================
% 参考文献格式设置
%
% 写作指南要求：
% 1. “参考文献”四个字的格式与章标题格式相同；
% 2. 参考文献正文为五号字；
% 3. 汉字用宋体，英文用 Times New Roman；
% 4. 行距采用固定值 16 磅；
% 5. 段前空 3 磅，段后空 0 磅；
% 6. 每一条文献内容尽量写在同一页内。
%=========================================

\makeatletter

% 参考文献标题名称
\renewcommand{\bibname}{参考文献}

% 参考文献正文格式
% 说明：
% thebibliography 本质上是一个列表环境。
% 这里在列表初始化之后统一设置字体、字号、固定行距与条目间距。
\AddToHook{cmd/thebibliography/after}{%
	\songti\fontspec{Times New Roman}\zihao{5}%
	\setlength{\baselineskip}{16pt}%
	\selectfont
	\setlength{\itemsep}{3pt}%
	\setlength{\parsep}{0pt}%
	\setlength{\parskip}{0pt}%
	\setlength{\topsep}{0pt}%
	\setlength{\partopsep}{0pt}%
	\setlength{\labelsep}{0.5em}%
	\interlinepenalty=8000%
	\clubpenalty=10000%
	\widowpenalty=10000%
	\sloppy
}

% 若参考文献宏包定义了 \bibsep，则同步设置条目间距。
\AtBeginDocument{%
	\@ifundefined{bibsep}{}{%
		\setlength{\bibsep}{3pt}%
	}%
}

% 参考文献编号右对齐，例如 [1]、[12] 的右边界对齐。
\renewcommand\@biblabel[1]{\hfill[#1]}

\makeatother

